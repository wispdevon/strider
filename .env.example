# Environment variables for Strider (copy to .env and fill in)
# Generate a strong value: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"

# Secret used to encrypt the session cookie. REQUIRED in production.
# Never reuse the dev default. Use a unique 48-byte random string.
SESSION_SECRET=

# Optional admin-only API token. Enables /api/auth/avatar/reset when set.
# Leave unset in production unless you actively need that maintenance endpoint.
ADMIN_API_TOKEN=

# WebAuthn Relying Party configuration
# RP_ID: the hostname users will access the app from (e.g. strider.example.com)
# For the deployed site this must equal the public domain.
RP_ID=boards.devonlabs.space
# RP_ORIGIN: the full origin URL (e.g. https://strider.example.com)
RP_ORIGIN=https://boards.devonlabs.space

# Canonical public URL used for absolute Open Graph and social preview metadata.
SITE_URL=https://boards.devonlabs.space

# Host/port the Next.js server binds to. Keep it on localhost and let Caddy
# (see Caddyfile) be the only public entrypoint.
HOSTNAME=127.0.0.1
PORT=3000
