# Caddy configuration for Strider
#
# Public site: boards.devonlabs.space  (automatic HTTPS via ACME)
# Local network: boards.lan           (self-signed HTTPS via Caddy's internal CA)
#
# The Next.js server must bind to 127.0.0.1:4000 (see below).
# Caddy terminates TLS and forwards X-Forwarded-* headers, which Strider's
# rate limiter (proxy.ts) and secure session cookies rely on.

# ---- Public, internet-facing site ----
boards.devonlabs.space {
    encode zstd gzip

    # Forward real client IP + scheme so rate limiting and secure cookies work.
    reverse_proxy 127.0.0.1:4000 {
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Real-IP {remote_host}
    }
}


# ---- Local network site ----
# Resolve "boards.lan" to this machine's LAN IP in your router's DNS or in
# each device's hosts file. Caddy issues a locally-trusted certificate; install
# Caddy's root CA on your devices once (see `caddy trust` / docs) to avoid
# browser warnings.
boards.lan {
    tls internal

    encode zstd gzip

    reverse_proxy 127.0.0.1:4000 {
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Real-IP {remote_host}
    }
}
